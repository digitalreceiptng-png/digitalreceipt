{
  "name": "digitalreceipt-desktop",
  "version": "1.0.0",
  "description": "DigitalReceipt.ng Desktop App for Windows",
  "main": "main.js",
  "author": "DigitalReceipt.ng",
  "scripts": {
    "start": "electron .",
    "build": "electron-packager . DigitalReceipt --platform=win32 --arch=x64 --icon=assets/icon.ico --out=dist --overwrite --asar",
    "dist": "electron-builder --win --x64 --ia32"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-packager": "^17.1.2",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "ng.digitalreceipt.desktop",
    "productName": "DigitalReceipt",
    "files": [
      "main.js",
      "index.html",
      "assets/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DigitalReceipt"
    },
    "artifactName": "DigitalReceipt-Setup-${version}.${ext}"
  }
}
